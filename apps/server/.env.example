# Database Configuration
DATABASE_URL=file:./dev.db

# Server Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Examples:
# CORS_ORIGINS=http://192.168.1.100:3000,https://myapp.com
# CORS_ORIGINS=https://staging.myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# GraphQL Configuration (client-side env vars)
# These would go in your client .env.local file:
# NEXT_PUBLIC_GRAPHQL_URL=http://192.168.5.106:4000/graphql
# NEXT_PUBLIC_WS_URL=ws://192.168.5.106:4000/graphql